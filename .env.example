# ─────────────────────────────────────────────────────
# Cosmetic AI Agent — Environment Variables (example)
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit secrets.
# ─────────────────────────────────────────────────────

# ===== App =====
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# ===== PostgreSQL (业务数据 + 向量库) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cosmetic
POSTGRES_PASSWORD=cosmetic_dev_pwd
POSTGRES_DB=cosmetic
DATABASE_URL=postgresql+asyncpg://cosmetic:cosmetic_dev_pwd@localhost:5432/cosmetic

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ===== LLM (OpenAI-compatible API) =====
# 支持任何兼容 OpenAI SDK 的服务：Qwen (DashScope) / DeepSeek / OpenAI / 自部署 vLLM 等
#
# Qwen (阿里云百炼，默认推荐)：
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-plus       # 可选：qwen-turbo / qwen-plus / qwen-max / qwen-long
#   申请 key: https://bailian.console.aliyun.com/
#
# DeepSeek：
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#   申请 key: https://platform.deepseek.com/
#
# OpenAI：
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ===== Embedding (SiliconFlow / 自部署) =====
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# ===== Langfuse (observability) =====
LANGFUSE_PORT=3000
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_NEXTAUTH_SECRET=please_generate_a_random_32+_char_secret
LANGFUSE_SALT=please_generate_a_random_32+_char_salt
